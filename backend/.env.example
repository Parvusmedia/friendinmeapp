# App
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-in-production
JWT_SECRET=change-me-jwt-secret-min-32-chars-long!!
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Database (PostgreSQL)
DATABASE_URL=postgresql://friendinme:friendinme@localhost:5432/friendinme

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Producción (ejemplo): CORS_ORIGINS=https://friendinme.pmediaplus.com

# Public URL for links in emails and media URLs
PUBLIC_BASE_URL=http://localhost:3000
# Producción (ejemplo): PUBLIC_BASE_URL=https://friendinme.pmediaplus.com

# Uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=5
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# Bulk import (ZIP: perros.csv + fotos/*.zip per dog)
IMPORT_STAGING_DIR=./import_staging
MAX_IMPORT_ZIP_MB=200
MAX_PHOTOS_PER_DOG=30
IMPORT_JOB_TTL_HOURS=24

# OpenAI (optional — fallback uses rule-based text if missing)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# SMTP (optional — logs email body in dev if unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true
MAIL_FROM=noreply@friendinme.com
ADMIN_NOTIFY_EMAIL=
